# ─────────────────────────────────────────────────────────────
#  Job Hunter — Environment Configuration
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── AI: Google Gemini (FREE via aistudio.google.com) ─────────
# Get your free API key at: https://aistudio.google.com/app/apikey 
# DO NOT connect a billing account to your API Key. Even if you have a Gemini Pro Subscription
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite

# ── Notion Integration ────────────────────────────────────────
# Step 1: Create integration at https://www.notion.so/my-integrations
# Step 2: Create a blank page in Notion, click ··· → Add connections → pick your integration
# Step 3: Copy the page URL: notion.so/My-Page-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
#         The last 32 chars (without dashes) = NOTION_PARENT_PAGE_ID
# Step 4: Connect Integration to page and also get the intergraftion token
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Leave NOTION_DB_ID empty — the script auto-creates the database on first run
# After first run, the script will print the DB ID. You can optionally paste it here to skip creation:
NOTION_DB_ID=

# ── Email Finding (both optional, free tiers) ─────────────────
# Hunter.io: 25 free searches/month — https://hunter.io/api-keys
HUNTER_API_KEY=

# Apollo.io: 50 free credits/month — https://developer.apollo.io
APOLLO_API_KEY=

# ── Your Resume ───────────────────────────────────────────────
# Supports .pdf, .docx, or .txt
RESUME_PATH=resume.pdf

# ── Job Search Configuration ──────────────────────────────────
# Search terms (comma-separated)
SEARCH_TERMS=software engineer,python developer,backend engineer

# Locations (pipe-separated — commas are part of location names!)
# Examples: Hyderabad. India|Dubai, UAE|Toronto, Canada|Singapore|Remote
LOCATIONS=

# Sites to scrape (comma-separated: linkedin, indeed, glassdoor, zip_recruiter, google)
JOB_SITES=linkedin,indeed,glassdoor

# How many results per location+term combination
RESULTS_PER_LOCATION=15

# Only show jobs posted in the last N hours
HOURS_OLD=72

# ── Local Storage ─────────────────────────────────────────────
DB_PATH=jobs.db
